{
  "chains": [
    {
      "id": "build-analyze-transpose",
      "description": "Construct chord → detect type → transpose → verify output",
      "steps": [
        {"cluster": "chord-construct", "input": "Cmaj7"},
        {"cluster": "chord-detect", "input": "Cmaj7"},
        {"cluster": "chord-transpose", "input": ["Cmaj7", 2]}
      ]
    },
    {
      "id": "scale-to-progression",
      "description": "Construct scale → generate chord progression → detect scale from chord",
      "steps": [
        {"cluster": "scale-construct", "input": ["C", "major"]},
        {"cluster": "chord-progression", "input": ["C", "major"]},
        {"cluster": "scale-detect", "input": "Cmaj7"}
      ]
    },
    {
      "id": "chord-transform-flow",
      "description": "Construct chord → invert → transpose → concat",
      "steps": [
        {"cluster": "chord-construct", "input": "Cmaj7"},
        {"cluster": "chord-inversion", "input": ["Cmaj7", 1]},
        {"cluster": "chord-transpose", "input": ["Cmaj7", 5]},
        {"cluster": "chord-concat", "input": ["Cmaj7", "Dm7"]}
      ]
    }
  ]
}
